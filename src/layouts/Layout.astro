---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "SmartCalc Hub - 實用理財與生活計算器大全" } = Astro.props;
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#4f46e5" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<meta name="apple-mobile-web-app-title" content="SmartCalc" />

		<meta name="generator" content={Astro.generator} />
		<title>{title} | SmartCalc Hub</title>
		
		<!-- JSON-LD Structured Data for Financial Tool -->
		<script type="application/ld+json">
		{
		  "@context": "https://schema.org",
		  "@type": "WebApplication",
		  "name": "{title}",
		  "description": "{description}",
		  "applicationCategory": "FinancialApplication",
		  "operatingSystem": "Any",
		  "offers": {
		    "@type": "Offer",
		    "price": "0",
		    "priceCurrency": "TWD"
		  }
		}
		</script>

		<!-- Google Fonts: Inter & Noto Sans TC -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
		
		<!-- Google tag (gtag.js) -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-9TREB203NC"></script>
		<script is:inline>
		  window.dataLayer = window.dataLayer || [];
		  function gtag(){dataLayer.push(arguments);}
		  gtag('js', new Date());

		  gtag('config', 'G-9TREB203NC');
		</script>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans antialiased min-h-screen flex flex-col">
		<slot />
	</body>
</html>
